# --- Server ---
PORT=3000
# Comma-separated list of allowed CORS origins (the dashboard / frontend origin).
# In production set this to the real dashboard URL(s) — do NOT use a wildcard.
CORS_ORIGIN=http://localhost:5173

# --- Auth (single admin login) ---
# Verified server-side. These are NOT exposed to any client bundle.
# Choose a strong password — the app rejects the well-known defaults.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
# Secret used to sign JWTs. MUST be a long random value — the app refuses to
# start if this is unset or left as the old "dev-secret-change-me" placeholder.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
# Token lifetime (e.g. 60s, 30m, 1d). See @nestjs/jwt expiresIn.
JWT_EXPIRES_IN=1d

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=hpd_booking

# Auto-create/update tables from entities. Great for development, NEVER use in
# production — set to false and run migrations instead.
DB_SYNCHRONIZE=true
